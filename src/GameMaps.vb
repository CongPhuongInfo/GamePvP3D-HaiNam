Imports System
Imports System.Collections.Generic
Imports System.Drawing

' =====================================================================
'  Form1 - Maps: dinh nghia toan bo cac map co the choi.
'  (Mot phan cua Form1 - xem README.md muc 'Cau truc code' de biet
'  toan bo cac file partial class va vai tro cua tung file)
'
'  CAU TRUC (tu 2026-07, refactor lai tu Select Case rai rac sang list):
'  Moi map la 1 MapDefinition (ten + layout + den duoc + diem spawn), gom
'  lai trong ham BuildMaps() ben duoi. Muon THEM MAP MOI thi:
'    1) Viet 1 ham Layout_TenMap() rieng tra ve Integer(,) 32x32
'       (dam bao o (1,1) = 0 - dat trong - de khong ket vao tuong luc spawn).
'    2) (Tuy chon) viet 1 ham Torches_TenMap() tra ve TorchLight() - map
'       ngoai troi ban ngay thi tra ve mang rong New TorchLight() {}.
'    3) Them 1 dong .Add(New MapDefinition With {...}) trong BuildMaps().
'  CHI CAN SUA 1 CHO DUY NHAT (BuildMaps) - khong con phai dong bo thu
'  tu giua nhieu Select Case va mot mang ten rieng nhu truoc nua, nen se
'  khong bao gio bi lech idx giua ten/layout/den/spawn.
'
'  LUU Y KICH THUOC: MAP_W/MAP_H = 32x32 (Form1.vb), CHUNG cho moi map.
'  3 map me cung dau tien (0,1,2) la mang 16x16 GOC, chi duoc DEM THEM
'  tuong da (gia tri 1) o nua duoi/nua phai cho du 32x32 - khu vuc choi
'  thuc te cua chung khong doi. Map "Canh Dong Rong" dung het 32x32.
' =====================================================================

Partial Public Class Form1

    ' Mot dinh nghia map day du: ten hien thi, layout o, den duoc, diem spawn.
    Private Structure MapDefinition
        Public Name As String
        Public Layout As Integer(,)
        Public Torches As TorchLight()
        Public Spawn As PointF
        Public FogDistance As Double ' tam nhin (so o) truoc khi suong che het - 12 = kin nhu me cung, cang lon cang nhin xa
    End Structure

    ' Danh sach map, khoi tao 1 lan duy nhat (Shared - dung chung cho moi Form1,
    ' khong doi trong luc choi). Them map moi CHI CAN sua ham BuildMaps() ben duoi.
    Private Shared ReadOnly Maps As List(Of MapDefinition) = BuildMaps()

    ' Ten hien thi cho ComboBox chon map trong ConnectForm (Form1.MapNames van
    ' dung duoc y het truoc day - chi doi tu mang co dinh sang property tinh
    ' tu Maps de khong bao gio lech voi du lieu layout/spawn thuc te).
    Public Shared ReadOnly Property MapNames As String()
        Get
            Dim names(Maps.Count - 1) As String
            For i As Integer = 0 To Maps.Count - 1
                names(i) = Maps(i).Name
            Next
            Return names
        End Get
    End Property

    Private Shared Function BuildMaps() As List(Of MapDefinition)
        Dim list As New List(Of MapDefinition)

        list.Add(New MapDefinition With {
            .Name = "Me Cung Co (map goc)",
            .Layout = Layout_MeCungCo(),
            .Torches = Torches_MeCungCo(),
            .Spawn = New PointF(1.5F, 1.5F),
            .FogDistance = 12.0
        })

        list.Add(New MapDefinition With {
            .Name = "Rung Mo",
            .Layout = Layout_RungMo(),
            .Torches = Torches_RungMo(),
            .Spawn = New PointF(1.5F, 1.5F),
            .FogDistance = 12.0
        })

        list.Add(New MapDefinition With {
            .Name = "Hang Da Reu",
            .Layout = Layout_HangDaReu(),
            .Torches = Torches_HangDaReu(),
            .Spawn = New PointF(1.5F, 1.5F),
            .FogDistance = 12.0
        })

        ' FogDistance 40.0: nhin xa gan sat duong cheo ban do 32x32 (~45.3) - thay 26 cu, mo rong tam nhin
        list.Add(New MapDefinition With {
            .Name = "Canh Dong Rong (ngoai troi)",
            .Layout = Layout_CanhDongRong(),
            .Torches = Torches_CanhDongRong(),
            .Spawn = New PointF(1.5F, 1.5F),
            .FogDistance = 40.0
        })

        Return list
    End Function

    ' Goi 1 lan luc chon map (Sub New, hoac khi Client nhan WELCOME bao map that cua
    ' Host khac voi map dang dung). Gan lai toan bo du lieu phu thuoc map: mapData,
    ' torchLights, vi tri spawn cua CHINH MINH, roi tinh lai trang tri (SpawnDecorations
    ' dung Random seed CO DINH + mapData hien tai nen ket qua giong het nhau tren moi may
    ' mien la cung mapData - xem ghi chu o SpawnDecorations trong GameWorld.vb).
    Private Sub ApplyMapSelection(idx As Integer)
        If idx < 0 OrElse idx >= Maps.Count Then idx = 0
        currentMapIndex = idx
        Dim def As MapDefinition = Maps(idx)
        mapData = def.Layout
        torchLights = def.Torches
        mapFogDist = def.FogDistance

        playerX = def.Spawn.X
        playerY = def.Spawn.Y
        playerAngle = 0.3
        playerZ = 0.0 : crouchAmount = 0.0 : zVelocity = 0.0 : isJumping = False

        SpawnDecorations()
    End Sub

